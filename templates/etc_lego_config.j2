#
# {{ ansible_managed }}
#
{% if lego_list_of_clients is defined %}
LEGO_PATH="{{ item['lego_path'] }}"
DOMAIN="{{ item['lego_domain'] }}"
EMAIL="{{ item['lego_email'] }}"
SERVER="{{ item['lego_server'] | default(lego_server) }}"
ARGS="{{ item['lego_args'] }}"
RENEW_ARGS="{{ item['lego_renew_args'] }}"
{% else %}
LEGO_PATH="{{ lego_path }}"
DOMAIN="{{ lego_domain }}"
EMAIL="{{ lego_email }}"
SERVER="{{ lego_server }}"
ARGS="{{ lego_args }}"
RENEW_ARGS="{{ lego_renew_args }}"
{% endif %}
