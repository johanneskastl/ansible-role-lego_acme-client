#!/bin/bash
#
# {{ ansible_managed }}
#

set -o allexport
source /etc/default/lego
{% if lego_list_of_clients is defined %}
source /etc/lego/config-{{ item['name'] }}
{% else %}
source /etc/lego/config
{% endif %}
set +o allexport

{% if variables_to_check_for_being_set is defined %}
{% for variable_to_check in variables_to_check_for_being_set %}
[[ -z "${{ '{' }}{{ variable_to_check }}{{ '}' }}" ]] && {
    echo "Error, {{variable_to_check}} is unset..."
    exit 3
}
{% endfor%}
{% endif%}

[ -z "${EMAIL}" ] && {
        echo "EMAIL is not set..."
        exit 1
}

[ -z "${ARGS}" ] && {
        echo "ARGS is not set..."
        exit 1
}

[ -z "${RENEW_ARGS}" ] && {
        echo "RENEW_ARGS is not set..."
        exit 1
}

[ -z "${SERVER}" ] && {
        echo "SERVER is not set..."
        exit 1
}

[ -z "${LEGO_PATH}" ] && {
        echo "LEGO_PATH is not set..."
        exit 1
}

[ -z "${DOMAIN}" ] && [ -z "${MULTIPLE_DOMAINS_OR_IP_ADDRESSES}" ] && {
        echo "Neither DOMAIN nor MULTIPLE_DOMAINS_OR_IP_ADDRESSES are not set..."
        exit 1
}

[ -n "${DOMAIN}" ] && [ -n "${MULTIPLE_DOMAINS_OR_IP_ADDRESSES}" ] && {
        echo "Both DOMAIN and MULTIPLE_DOMAINS_OR_IP_ADDRESSES are set..."
        exit 1
}

echo "EMAIL is set to ${EMAIL}"
echo "ARGS is set to ${ARGS}"
echo "RENEW_ARGS is set to ${RENEW_ARGS}"
echo "SERVER is set to ${SERVER}"
echo "LEGO_PATH is set to ${LEGO_PATH}"

if [ -n "${DOMAIN}" ]
then

    echo "DOMAIN is set to ${DOMAIN}"

    LEGO_DOMAIN_ARGS="--domains ${DOMAIN}"

    {% if lego_add_ip_address_to_certificate | bool %}
    LEGO_DOMAIN_ARGS+=" --domains {{ hostvars[inventory_hostname]['ansible_default_ipv4']['address'] }}"
    {% endif %}
fi

if [ -n "${MULTIPLE_DOMAINS_OR_IP_ADDRESSES}" ]
then

    echo "MULTIPLE_DOMAINS_OR_IP_ADDRESSES is set to ${MULTIPLE_DOMAINS_OR_IP_ADDRESSES}"

    read -r -a ARRAY_MULTIPLE_DOMAINS_OR_IP_ADDRESSES <<<"${MULTIPLE_DOMAINS_OR_IP_ADDRESSES}"
    for element in "${ARRAY_MULTIPLE_DOMAINS_OR_IP_ADDRESSES[@]}"
    do
        LEGO_DOMAIN_ARGS+=" --domains ${element}"
    done

    {% if lego_add_ip_address_to_certificate | bool %}
    LEGO_DOMAIN_ARGS+=" --domains {{ hostvars[inventory_hostname]['ansible_default_ipv4']['address'] }}"
    {% endif %}

fi

#
# Ready for take-off
#
{# ARGS and LEGO_DOMAIN_ARGS MUST NOT be quoted... #}
{{ path_to_lego }} --accept-tos --path "${LEGO_PATH}" --email "${EMAIL}" --server "${SERVER}" ${ARGS} ${LEGO_DOMAIN_ARGS} run
